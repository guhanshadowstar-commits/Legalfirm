        "jsCode": "const rows = $input.all().map(r => r.json);\nconst tomorrow = new Date();\ntomorrow.setDate(tomorrow.getDate() + 1);\nconst tomorrowStr = tomorrow.toISOString().split('T')[0];\n\nconst due = rows.filter(r => {\n  if (!r['Appointment Date'] || r['Reminder Sent'] === 'yes' || r['Status'] === 'cancelled') return false;\n  const apptDate = new Date(r['Appointment Date']).toISOString().split('T')[0];\n  return apptDate === tomorrowStr;\n});\n\nif (due.length === 0) return [];\nreturn due.map(r => ({ json: r }));"
