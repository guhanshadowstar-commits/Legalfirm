        "jsCode": "const rows = $input.all().map(r => r.json);\nconst sevenDaysAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);\nconst recent = rows.filter(r => r.Timestamp && new Date(r.Timestamp) > sevenDaysAgo);\n\nif (recent.length < 3) {\n  return [{ json: { skip: true, reason: 'Less than 3 calls this week' } }];\n}\n\nconst avgScore = (recent.reduce((s, r) => s + Number(r['Overall Score'] || 5), 0) / recent.length).toFixed(1);\nconst worstMoments = recent\n  .filter(r => r['Worst Moment'] && r['Fix Suggestion'])\n  .map(r => `- Worst: \"${r['Worst Moment']}\" → Fix: ${r['Fix Suggestion']}`)\n  .join('\\n');\n\nconst byType = {};\nrecent.forEach(r => {\n  const t = r['Call Type'] || 'unknown';\n  if (!byType[t]) byType[t] = { total: 0, sum: 0 };\n  byType[t].total++;\n  byType[t].sum += Number(r['Overall Score'] || 5);\n});\nconst typeBreakdown = Object.entries(byType)\n  .map(([t, v]) => `${t}: ${(v.sum / v.total).toFixed(1)}/10 (${v.total} calls)`)\n  .join('\\n');\n\nreturn [{ json: { recent_count: recent.length, avg_score: avgScore, worst_moments: worstMoments, type_breakdown: typeBreakdown, skip: false } }];"
      },
