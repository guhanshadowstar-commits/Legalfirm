    {
      "parameters": {
        "jsCode": "const msg = $input.first().json.message;\nconst call = msg.call || {};\nconst transcript = msg.transcript || '';\nconst summary = msg.analysis?.summary || '';\nconst structuredData = msg.analysis?.structuredData || {};\n\nreturn [{\n  json: {\n    call_id: call.id || '',\n    call_type: call.metadata?.call_type || 'inbound',\n    caller_phone: call.customer?.number || '',\n    caller_name: structuredData.name || call.customer?.name || 'Unknown',\n    caller_email: structuredData.email || '',\n    caller_need: structuredData.need || '',\n    caller_timeline: structuredData.timeline || '',\n    summary: summary,\n    transcript: transcript,\n    duration_seconds: call.endedAt && call.startedAt\n      ? Math.round((new Date(call.endedAt) - new Date(call.startedAt)) / 1000)\n      : 0,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "1a8d638c-a1d0-4a78-97bb-b4e250c29794",
      "name": "Parse call data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [176, 320]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst transcript = item.transcript;\n\n// Default when transcript is too short to analyze\nif (!transcript || transcript.length < 50) {\n  return [{ json: { ...item, name: '', email: '', need: '', timeline: '',\n    interest_level: 'unknown', call_outcome: 'unknown',\n    overall_score: 5, hook_score: 5, naturalness_score: 5, objection_score: 5, close_score: 5,\n    worst_moment: 'call too short to evaluate', fix_suggestion: '' } }];\n}\n\n// Single Groq call does lead extraction AND call-quality grading at once.\nconst response = await fetch('https://api.groq.com/openai/v1/chat/completions', {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application/json',\n    'Authorization': `Bearer ${$env.GROQ_API_KEY}`\n  },\n  body: JSON.stringify({\n    model: 'llama-3.3-70b-versatile',\n    temperature: 0.1,\n    max_tokens: 600,\n    messages: [{\n      role: 'user',\n      content: `You are analyzing a voice agent call transcript. Do two things at once: (1) extract lead info, (2) grade the agent's performance.\\n\\nCALL TYPE: ${item.call_type}\\nTRANSCRIPT:\\n${transcript}\\n\\nRespond ONLY in valid JSON, no markdown:\\n{\\n  \"name\": \"full name or empty string\",\\n  \"email\": \"email address or empty string\",\\n  \"need\": \"what they want in one sentence or empty string\",\\n  \"timeline\": \"when they need it or empty string\",\\n  \"interest_level\": \"hot|warm|cold\",\\n  \"call_outcome\": \"lead_captured|appointment_booked|not_interested|callback_requested|hung_up\",\\n  \"hook_score\": 0,\\n  \"naturalness_score\": 0,\\n  \"objection_score\": 0,\\n  \"close_score\": 0,\\n  \"overall_score\": 0,\\n  \"worst_moment\": \"exact quote of the weakest agent line\",\\n  \"fix_suggestion\": \"one specific rule to add to the system prompt to prevent this\"\\n}`\n    }]\n  })\n});\n\nconst data = await response.json();\nlet extracted = {};\ntry {\n  const raw = data.choices[0].message.content.trim();\n  extracted = JSON.parse(raw.replace(/```json|```/g, '').trim());\n} catch (e) {\n  extracted = { parse_error: true, overall_score: 5 };\n}\n\nreturn [{ json: { ...item, ...extracted } }];"
      },
      "id": "7570333d-7329-493b-8842-37c0b2cec777",
      "name": "Groq — extract & grade",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 320]
