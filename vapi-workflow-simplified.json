    {
      "parameters": {
        "jsCode": "const row = $input.first().json;\n\nconst callType = row['Call Type'] || 'cold_outreach';\nconst phone = row['Phone'] || '';\nconst name = row['Name'] || '';\n\nif (!phone) {\n  throw new Error(`Row missing phone number: ${JSON.stringify(row)}`);\n}\n\nlet context = '';\nif (callType === 'follow_up') {\n  context = `Last spoke on ${row['Last Contact'] || 'N/A'}. Interest: ${row['Interest Level'] || 'unknown'}. Previous need: ${row['Need'] || 'N/A'}.`;\n} else if (callType === 'reminder') {\n  context = `Appointment: ${row['Appointment Details'] || 'N/A'}.`;\n} else if (callType === 'cold_outreach') {\n  context = `Business type: ${row['Business Type'] || 'N/A'}. Source: ${row['Source'] || 'N/A'}.`;\n}\n\nreturn [{\n  json: {\n    phone: phone.startsWith('+') ? phone : `+1${phone.replace(/\\D/g, '')}`,\n    name: name,\n    call_type: callType,\n    context: context,\n    appointment_details: row['Appointment Details'] || '',\n    row_id: row['Row ID'] || '',\n    sheet_row: row\n  }\n}];"
      },
