      "id": "613edf87-5337-402b-97cc-2f15c064fb28",
      "name": "Enough data?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [416, 1184]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst prompt = `You are a voice agent prompt engineer. Based on this week's call quality data, suggest exactly 3 prompt improvements.\\n\\nWeekly summary:\\n- Total calls: ${data.recent_count}\\n- Average score: ${data.avg_score}/10\\n- Score by scenario:\\n${data.type_breakdown}\\n\\nRecurring failure patterns:\\n${data.worst_moments}\\n\\nRespond ONLY in valid JSON:\\n{\\n  \"weekly_summary\": \"2-sentence summary of the week\",\\n  \"improvements\": [\\n    { \"issue\": \"what kept failing\", \"rule\": \"exact rule to add to system prompt\" },\\n    { \"issue\": \"what kept failing\", \"rule\": \"exact rule to add to system prompt\" },\\n    { \"issue\": \"what kept failing\", \"rule\": \"exact rule to add to system prompt\" }\\n  ]\\n}`;\n\nconst response = await fetch('https://api.groq.com/openai/v1/chat/completions', {\n  method: 'POST',\n  headers: {\n    'Content-Type': 'application/json',\n    'Authorization': `Bearer ${$env.GROQ_API_KEY}`\n  },\n  body: JSON.stringify({\n    model: 'llama-3.3-70b-versatile',\n    temperature: 0.2,\n    max_tokens: 600,\n    messages: [{ role: 'user', content: prompt }]\n  })\n});\n\nconst res = await response.json();\nlet result = {};\ntry {\n  result = JSON.parse(res.choices[0].message.content.trim().replace(/```json|```/g, '').trim());\n} catch (e) {\n  result = { parse_error: true, improvements: [] };\n}\n\nreturn [{ json: { ...data, ...result } }];"
      },
